//- index.pug
doctype html
html
  head
    title Dance Academy
    style
      include ../static/style.css
  body
    nav#navbar 
        div#logo
            img(src="/static/dancelogo.jpg")
            | WDA
        ul 
            li #[a(href="/") Home ]
            li #[a(href="/") About]
            li #[a(href="/") Services]
            li #[a(href="/") Class Info] 
            li #[a(href="/") Contact]

    section#introSection 
        div Welcome To My Academy
        div.small Eat Sleep Dance Repeat

    section#missionSection 
        h2 Our Mission
        div.card
            h3 Dance Perfection
            div.card-box
                div.card-img
                    img(src="/static/img1.jpg")
                div.card-content
                    p This is the best dance academy of the universe
        div.card
            h3 Dance the way you like
            div.card-box
                div.card-img
                    img(src="/static/img2.webp")
                div.card-content
                    p This is the best dance academy of the universe
        div.card
            h3 Expert Teaching
            div.card-box
                div.card-img
                    img(src="/static/img3.webp")
                div.card-content
                    p This is the best dance academy of the universe

    section#sponsorSection 
        h2 Our Sponsors
        div#sponsors
            img(src="/static/aws.png", alt="Sponsor Image", class="spImage")
            img(src="/static/hp.png", alt="Sponsor Image", class="spImage")
            img(src="/static/micro.png", alt="Sponsor Image", class="spImage")
        p.small Supporting the arts in our community.

    section#footer 
        | Copyright © 2026 DanceAcademy.com | All Rights Reserved
    script
      include ../static/index.js